{
  "uid": "raft-playground",
  "title": "ryanDB",
  "tags": ["raft", "playground"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Leader count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftdb_leader_count", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Current term",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(raftdb_term)", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "Nodes running",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftdb_nodes_running", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Commit spread",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(raftdb_commit_index) - min(raftdb_commit_index)", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "Commit index by node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftdb_commit_index", "legendFormat": "{{node}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2 } } }
    },
    {
      "id": 6,
      "title": "Replication lag by node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftdb_replication_lag", "legendFormat": "{{node}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2 } } }
    },
    {
      "id": 9,
      "title": "Election rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(raftdb_elections_total[1m]))", "legendFormat": "elections/s", "refId": "A" }]
    },
    {
      "id": 10,
      "title": "Commit rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(raftdb_commits_total[1m]))", "legendFormat": "commits/s", "refId": "A" }]
    }
  ]
}
