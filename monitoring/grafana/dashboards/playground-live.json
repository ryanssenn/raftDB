{
  "uid": "playground-live",
  "title": "Playground Live",
  "tags": ["raft", "playground"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Write throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(raftdb_client_requests_total{op=\"put\",result=\"success\"}[30s]))",
          "legendFormat": "writes/s",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        }
      }
    },
    {
      "id": 2,
      "title": "Read throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(raftdb_client_requests_total{op=\"get\",result=\"success\"}[30s]))",
          "legendFormat": "reads/s",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        }
      }
    },
    {
      "id": 3,
      "title": "Latency p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(raftdb_client_request_duration_seconds_bucket{op=\"put\"}[30s])) by (le)) * 1000",
          "legendFormat": "write p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(raftdb_client_request_duration_seconds_bucket{op=\"get\"}[30s])) by (le)) * 1000",
          "legendFormat": "read p99",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 8,
            "gradientMode": "none",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "write p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "read p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "Replication lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(raftdb_replication_lag)",
          "legendFormat": "max lag",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none" }
          },
          "unit": "short",
          "decimals": 0
        }
      }
    }
  ]
}
