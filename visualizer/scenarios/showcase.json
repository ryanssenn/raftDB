{
  "name": "Raft Demo Loop",
  "nodes": 5,
  "showcase": true,
  "loop": true,
  "durationMs": 60000,
  "scenes": [
    { "id": "empty", "title": "Empty cluster", "subtitle": "Machines waiting to join", "startMs": 0 },
    { "id": "join", "title": "Nodes joining", "subtitle": "Machines boot one at a time", "startMs": 300 },
    { "id": "elect", "title": "Leader elected", "subtitle": "One leader, remaining followers", "startMs": 2800 },
    { "id": "client", "title": "Client connects", "subtitle": "Writes begin flowing", "startMs": 3000 },
    { "id": "writes", "title": "Replicating", "subtitle": "Leader copies entries to every follower", "startMs": 4500 },
    { "id": "fail", "title": "Leader fails", "subtitle": "The leader stops responding", "startMs": 11500 },
    { "id": "elect2", "title": "New election", "subtitle": "Followers time out and vote", "startMs": 12500 },
    { "id": "leader2", "title": "New leader", "subtitle": "A replacement takes over", "startMs": 14500 },
    { "id": "rejoin", "title": "Node rejoins", "subtitle": "The failed leader catches up", "startMs": 19000 },
    { "id": "recovery", "title": "Steady state", "subtitle": "Writes continue under the new leader", "startMs": 21000 },
    { "id": "stable", "title": "Logs aligned", "subtitle": "All replicas converge", "startMs": 54000 }
  ],
