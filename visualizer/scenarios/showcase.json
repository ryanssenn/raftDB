{
  "name": "Raft Demo Loop",
  "nodes": 5,
  "showcase": true,
  "loop": true,
  "durationMs": 60000,
  "scenes": [
    { "id": "empty", "title": "Empty cluster", "subtitle": "Five machines waiting to join", "startMs": 0 },
    { "id": "join", "title": "Nodes joining", "subtitle": "Machines boot one at a time", "startMs": 300 },
    { "id": "elect", "title": "Leader elected", "subtitle": "One leader, four followers", "startMs": 2800 },
    { "id": "client", "title": "Client connects", "subtitle": "Writes begin flowing", "startMs": 3000 },
    { "id": "writes", "title": "Replicating", "subtitle": "Leader copies entries to every follower", "startMs": 4500 },
    { "id": "fail", "title": "Leader fails", "subtitle": "The leader stops responding", "startMs": 12000 },
    { "id": "elect2", "title": "New election", "subtitle": "Followers time out and vote", "startMs": 13000 },
    { "id": "leader2", "title": "New leader", "subtitle": "A replacement takes over", "startMs": 17000 },
    { "id": "recovery", "title": "Recovery", "subtitle": "Replication resumes under the new leader", "startMs": 18000 },
    { "id": "stable", "title": "Logs aligned", "subtitle": "All replicas converge", "startMs": 48000 }
  ],
  "steps": [
    { "wait": "3s", "comment": "0–3s: empty stage → nodes join → election" },
    { "put": { "node": "node3", "key": "user:1", "value": "alice" }, "comment": "3s: first write" },
    { "wait": "1.5s" },
    { "put": { "node": "node5", "key": "user:2", "value": "bob" } },
    { "wait": "1.5s" },
    { "put": { "node": "node2", "key": "user:3", "value": "carol" } },
    { "wait": "1.5s" },
    { "put": { "node": "node1", "key": "user:4", "value": "dave" }, "comment": "before kill — node4 is leader, use other nodes" },
    { "wait": "1.5s" },
    { "put": { "node": "node3", "key": "user:5", "value": "eve" } },
    { "wait": "2s", "comment": "11s: pause before leader failure" },
    { "kill": "leader", "comment": "12s: kill leader (node4)" },
    { "wait": "4s", "comment": "12–16s: new election" },
    { "put": { "node": "node3", "key": "user:6", "value": "frank" }, "comment": "16s: first write under new leader — only live nodes" },
    { "wait": "1.5s" },
    { "put": { "node": "node5", "key": "user:7", "value": "grace" } },
    { "wait": "1.5s" },
    { "put": { "node": "node2", "key": "user:8", "value": "henry" } },
    { "wait": "1.5s" },
    { "put": { "node": "node1", "key": "user:9", "value": "iris" } },
    { "wait": "1.5s" },
    { "put": { "node": "node3", "key": "user:10", "value": "jack" } },
    { "wait": "1.5s" },
    { "put": { "node": "node5", "key": "user:11", "value": "kate" } },
    { "wait": "1.5s" },
    { "put": { "node": "node2", "key": "user:12", "value": "leo" } },
    { "wait": "1.5s" },
    { "put": { "node": "node1", "key": "user:13", "value": "mia" } },
    { "wait": "10s", "comment": "48–58s: stable cluster under new leader" },
    { "wait": "5s", "comment": "58–60s: loop restarts" }
  ]
}
