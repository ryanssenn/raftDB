{
  "name": "Node recovery",
  "nodes": 5,
  "steps": [
    { "wait": "2s", "comment": "wait for leader election" },
    { "put": { "node": "node1", "key": "key1", "value": "value1" } },
    { "wait": "1s" },
    { "put": { "node": "node2", "key": "key2", "value": "value2" } },
    { "wait": "1s" },
    { "kill": "node1", "comment": "kill a node with data" },
    { "wait": "1s" },
    { "put": { "node": "node3", "key": "key3", "value": "value3" } },
    { "wait": "2s" },
    { "restart": "node1", "comment": "bring node back and catch up" },
    { "wait": "4s" },
    { "get": { "node": "node1", "key": "key3", "expect": "value3" } }
  ]
}
