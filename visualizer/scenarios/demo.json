{
  "name": "Raft in Action",
  "nodes": 5,
  "steps": [
    { "wait": "3s", "comment": "initial leader election" },
    { "put": { "node": "node3", "key": "user:1", "value": "alice" }, "comment": "write via follower" },
    { "wait": "2s" },
    { "put": { "node": "node5", "key": "user:2", "value": "bob" } },
    { "wait": "2s" },
    { "put": { "node": "node2", "key": "user:3", "value": "carol" } },
    { "wait": "2s" },
    { "get": { "node": "node2", "key": "user:1", "expect": "alice" } },
    { "wait": "2s" },
    { "put": { "node": "node4", "key": "user:4", "value": "dave" } },
    { "wait": "2s" },
    { "kill": "leader", "comment": "kill the leader" },
    { "wait": "4s", "comment": "watch re-election" },
    { "put": { "node": "node2", "key": "user:5", "value": "eve" } },
    { "wait": "2s" },
    { "put": { "node": "node3", "key": "user:6", "value": "frank" } },
    { "wait": "2s" },
    { "restart": "killed", "comment": "revive the failed leader" },
    { "wait": "3s", "comment": "catch-up replication" },
    { "put": { "node": "node5", "key": "user:7", "value": "grace" } },
    { "wait": "2s" },
    { "put": { "node": "node1", "key": "user:8", "value": "henry" } },
    { "wait": "2s" },
    { "put": { "node": "node4", "key": "user:9", "value": "iris" } },
    { "wait": "2s" },
    { "get": { "node": "node1", "key": "user:9", "expect": "iris" } },
    { "wait": "2s" },
    { "put": { "node": "node3", "key": "user:10", "value": "jack" } },
    { "wait": "2s" },
    { "put": { "node": "node2", "key": "user:11", "value": "kate" } },
    { "wait": "2s" }
  ]
}
